<%- include('partials/header', { title, active }) %>

<p><a href="/runs/<%= score.runId %>">← Run #<%= score.runId %></a></p>
<h1><%= score.site.name %></h1>
<p class="muted"><%= categoryLabel(score.category) %> ·
  Global <span class="score <%= scoreClass(score.overall) %>"><%= fmtScore(score.overall) %></span>
  GEO <span class="score <%= scoreClass(score.geo) %>"><%= fmtScore(score.geo) %></span>
  China <span class="score <%= scoreClass(score.china) %>"><%= fmtScore(score.china) %></span>
</p>

<% (topics || []).forEach(function(t){ %>
  <h2><%= t.topicId %>. <%= t.name %> —
    <span class="score <%= scoreClass(t.score) %>"><%= fmtScore(t.score) %><% if (t.score!==null){ %>/100<% } %></span>
  </h2>
  <% if (t.score === null) { %>
    <p class="muted">N/A — aucun élément applicable détecté.</p>
  <% } else { %>
    <table class="grid small">
      <thead><tr><th>Critère</th><th>Pts</th><th></th><th>Évidence</th></tr></thead>
      <tbody>
        <% (t.controls||[]).forEach(function(c){ %>
          <tr>
            <td><%= c.label %></td>
            <td><% if (c.applicable) { %><%= c.pointsAwarded %>/<%= c.maxPoints %><% } else { %>—<% } %></td>
            <td><% if (!c.applicable) { %><span class="muted">N/A</span><% } else if (c.passed) { %><span class="ok">✓</span><% } else { %><span class="ko">✗</span><% } %></td>
            <td class="ev"><%= c.evidence %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
<% }) %>

<%- include('partials/footer') %>
