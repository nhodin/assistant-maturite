# Copy to .env and adjust. Used by Prisma (DATABASE_URL) and the web server (PORT).
DATABASE_URL="mysql://maturite:maturite@127.0.0.1:3306/maturite"
PORT=5173

# Optional — only needed for `npm run spike:cloudflare` (Cloudflare Browser Run
# feasibility spike). API token needs "Browser Rendering - Edit" permission.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
