  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^12.0.0",
    "@prisma/client": "^6.19.3",
    "cloakbrowser": "^0.4.5",
