    "csv-parse": "^5.5.6",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "fastify": "^5.9.0",
    "playwright": "^1.48.0",
    "playwright-core": "^1.61.1",
    "prisma": "^6.19.3",
